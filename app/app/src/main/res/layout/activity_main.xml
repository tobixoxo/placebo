<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/materialToolbar"
        android:layout_width="409dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvStreakName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Streak Name"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@+id/materialToolbar"
        app:layout_constraintEnd_toEndOf="@+id/materialToolbar"
        app:layout_constraintStart_toStartOf="@+id/materialToolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCurrentStreakLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="48dp"
        android:text="Current Streak:"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/materialToolbar" />

    <TextView
        android:id="@+id/tvLongestStreakLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Longest Streak:"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="@+id/tvCurrentStreakLabel"
        app:layout_constraintTop_toBottomOf="@+id/tvCurrentStreakLabel" />

    <TextView
        android:id="@+id/tvCurrentStreakValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="7"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/tvCurrentStreakLabel"
        app:layout_constraintStart_toEndOf="@+id/tvCurrentStreakLabel"
        app:layout_constraintTop_toTopOf="@+id/tvCurrentStreakLabel" />

    <TextView
        android:id="@+id/tvLongestStreakValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/tvLongestStreakLabel"
        app:layout_constraintStart_toStartOf="@+id/tvCurrentStreakValue"
        app:layout_constraintTop_toTopOf="@+id/tvLongestStreakLabel" />

    <ToggleButton
        android:id="@+id/tbMarkToday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:textOff="Mark for Today"
        android:textOn="Marked"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>